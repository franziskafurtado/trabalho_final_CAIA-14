vd:dataNascimento a owl:DatatypeProperty ;
    rdfs:label "data de nascimento"@pt ;
    rdfs:domain vd:Vitima ;
    rdfs:range xsd:date .

vd:dataNotificacao a owl:DatatypeProperty ;
    rdfs:label "data da notificação"@pt ;
    rdfs:domain vd:NotificacaoViolencia ;
    rdfs:range xsd:date .

vd:idade a owl:DatatypeProperty ;
    rdfs:label "idade"@pt ;
    rdfs:domain vd:Vitima ;
    rdfs:range xsd:integer .

vd:ocorreuEmLocal a owl:ObjectProperty ;
    rdfs:label "ocorreu em local"@pt ;
    rdfs:domain vd:NotificacaoViolencia ;
    rdfs:range vd:LocalOcorrencia .

vd:ocorreuEmMunicipio a owl:ObjectProperty ;
    rdfs:label "ocorreu em município"@pt ;
    rdfs:domain vd:NotificacaoViolencia ;
